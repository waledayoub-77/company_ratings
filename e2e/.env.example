# Copy this file to .env and fill in real values before running tests
FRONTEND_URL=http://localhost:5173

# ─── Employee account (must be verified + have approved employment) ─────────
EMPLOYEE_EMAIL=employee@test.com
EMPLOYEE_PASSWORD=Test1234!

# ─── Company Admin account (must own a company) ──────────────────────────────
COMPANY_ADMIN_EMAIL=companyadmin@test.com
COMPANY_ADMIN_PASSWORD=Test1234!

# ─── System Admin account ────────────────────────────────────────────────────
SYSTEM_ADMIN_EMAIL=admin@test.com
SYSTEM_ADMIN_PASSWORD=Test1234!

# ─── A second employee for feedback tests ────────────────────────────────────
EMPLOYEE2_EMAIL=employee2@test.com
EMPLOYEE2_PASSWORD=Test1234!

# ─── Optional: pre-suspended account for G22 / A14 tests ─────────────────────
SUSPENDED_EMAIL=suspended@test.com
SUSPENDED_PASSWORD=Test1234!

# ─── Optional: a real verify-email token for G26 test ────────────────────────
# Get this from the email sent during registration, or from Supabase auth logs
VERIFY_TOKEN=
