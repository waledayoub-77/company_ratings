          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Returns array', () => pm.expect(json.data).to.be.an('array'));",
                  "console.log('✅ Location search results:', json.data.length);"
                ]
              }
            }
          ]
        },
        {
          "name": "08 GET /companies — pagination page 2",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/companies?page=2&limit=3",
              "host": ["{{base_url}}"],
              "path": ["companies"],
              "query": [
                { "key": "page",  "value": "2" },
                { "key": "limit", "value": "3" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Page is 2', () => pm.expect(json.pagination.page).to.eql(2));",
                  "pm.test('Limit is 3', () => pm.expect(json.pagination.limit).to.eql(3));",
                  "console.log('✅ Page 2 returned', json.data.length, 'items');"
                ]
              }
            }
          ]
        },
        {
          "name": "09 GET /companies — page beyond total (edge case)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/companies?page=9999&limit=10",
              "host": ["{{base_url}}"],
              "path": ["companies"],
              "query": [
                { "key": "page",  "value": "9999" },
                { "key": "limit", "value": "10" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Returns empty array', () => pm.expect(json.data).to.be.an('array').that.is.empty);",
