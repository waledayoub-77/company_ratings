    {
      "name": "━━━ 4. REPORT REVIEW (CompanyProfilePage) ━━━",
      "item": [
        {
          "name": "18 POST /reports — no auth → 401",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reviewId\": \"{{review_id}}\",\n  \"reason\": \"spam\",\n  \"description\": \"Test report without auth\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/reports",
              "host": ["{{base_url}}"],
              "path": ["reports"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401 without token', () => pm.response.to.have.status(401));",
                  "console.log('✅ Unauthenticated report blocked with 401');"
                ]
              }
            }
          ]
        },
        {
          "name": "19 POST /reports — authenticated submit",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{employee_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reviewId\": \"{{review_id}}\",\n  \"reason\": \"false_information\",\n  \"description\": \"This review contains inaccurate claims about the company.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/reports",
              "host": ["{{base_url}}"],
              "path": ["reports"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const code = pm.response.code;",
                  "pm.test('Status 201 or 400 (duplicate)', () => pm.expect([201, 400, 409]).to.include(code));",
                  "if (code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.test('success is true', () => pm.expect(json.success).to.be.true);",
                  "  console.log('✅ Report submitted successfully');",
                  "} else {",
                  "  console.log('ℹ️ Report already exists or invalid — expected on re-run');",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
