                  "  pm.test('Review has overall_rating', () => pm.expect(r.overall_rating).to.be.a('number'));",
                  "  pm.test('Review has is_anonymous', () => pm.expect(r).to.have.property('is_anonymous'));",
                  "  pm.collectionVariables.set('review_id', r.id);",
                  "  console.log('✅ First review:', r.is_anonymous ? 'Anonymous' : r.reviewer_name, '|', r.overall_rating + '★');",
                  "} else {",
