            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Sorted alphabetically', () => {",
                  "  for (let i = 1; i < json.data.length; i++) {",
                  "    pm.expect(json.data[i-1].name.localeCompare(json.data[i].name)).to.be.at.most(0);",
                  "  }",
                  "});",
                  "console.log('✅ Alphabetical order:', json.data.map(c => c.name).join(', '));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "━━━ 3. COMPANY PROFILE (CompanyProfilePage) ━━━",
