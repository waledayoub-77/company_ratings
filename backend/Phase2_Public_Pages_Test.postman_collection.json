          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has company name', () => pm.expect(json.data.name).to.be.a('string'));",
                  "pm.test('Has industry', () => pm.expect(json.data.industry).to.be.a('string'));",
                  "pm.test('Has location', () => pm.expect(json.data.location).to.be.a('string'));",
                  "pm.test('Has overall_rating', () => pm.expect(json.data).to.have.property('overall_rating'));",
                  "pm.test('Has total_reviews', () => pm.expect(json.data).to.have.property('total_reviews'));",
                  "console.log('✅ Company:', json.data.name, '|', json.data.industry, '|', json.data.overall_rating + '★');"
                ]
              }
            }
          ]
        },
        {
          "name": "12 GET /companies/:id — invalid UUID → 404",
          "request": {
            "method": "GET",
            "header": [],
