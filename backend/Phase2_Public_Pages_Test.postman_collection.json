{
  "info": {
    "name": "Phase 2 – Public Pages API Tests (Walid)",
    "description": "Tests for CompaniesPage, CompanyProfilePage, LandingPage endpoints.\nCovers: GET /companies (filters/sort/pagination), GET /companies/:id, GET /companies/:id/reviews, GET /companies/:id/analytics, POST /reports.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",          "value": "http://localhost:5000/api" },
    { "key": "employee_token",    "value": "" },
    { "key": "employee_email",    "value": "your_employee@email.com" },
    { "key": "employee_password", "value": "your_password" },
    { "key": "company_id",        "value": "" },
    { "key": "review_id",         "value": "" }
  ],
  "item": [
    {
      "name": "━━━ SETUP ━━━",
      "item": [
        {
          "name": "01 Login as employee",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{employee_email}}\",\n  \"password\": \"{{employee_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login returns 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has accessToken', () => pm.expect(json.data.accessToken).to.be.a('string'));",
                  "pm.collectionVariables.set('employee_token', json.data.accessToken);",
                  "console.log('✅ Employee token saved');"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "━━━ 2. COMPANIES BROWSE (CompaniesPage) ━━━",
      "item": [
        {
          "name": "02 GET /companies — default (page 1)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/companies",
              "host": ["{{base_url}}"],
              "path": ["companies"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('success is true', () => pm.expect(json.success).to.be.true);",
                  "pm.test('data is array', () => pm.expect(json.data).to.be.an('array'));",
                  "pm.test('pagination exists', () => {",
                  "  pm.expect(json.pagination).to.have.property('total');",
                  "  pm.expect(json.pagination).to.have.property('page');",
                  "  pm.expect(json.pagination).to.have.property('totalPages');",
                  "});",
                  "if (json.data.length > 0) {",
                  "  pm.collectionVariables.set('company_id', json.data[0].id);",
                  "  console.log('✅ Saved company_id:', json.data[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "03 GET /companies — sorted by highest rated",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/companies?sortBy=overall_rating&sortOrder=desc&limit=4",
              "host": ["{{base_url}}"],
              "path": ["companies"],
              "query": [
                { "key": "sortBy",    "value": "overall_rating" },
                { "key": "sortOrder", "value": "desc" },
                { "key": "limit",     "value": "4" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Limit respected', () => pm.expect(json.data.length).to.be.at.most(4));",
                  "pm.test('Sorted desc by rating', () => {",
                  "  for (let i = 1; i < json.data.length; i++) {",
                  "    pm.expect(Number(json.data[i-1].overall_rating)).to.be.at.least(Number(json.data[i].overall_rating));",
                  "  }",
                  "});",
                  "console.log('✅ Top rated companies:', json.data.map(c => c.name + ' (' + c.overall_rating + ')').join(', '));"
                ]
              }
            }
          ]
        },
        {
          "name": "04 GET /companies — search by name",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/companies?search=a",
              "host": ["{{base_url}}"],
              "path": ["companies"],
              "query": [
                { "key": "search", "value": "a" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Returns array', () => pm.expect(json.data).to.be.an('array'));",
                  "console.log('✅ Search results:', json.data.length, 'companies');"
                ]
              }
            }
          ]
        },
