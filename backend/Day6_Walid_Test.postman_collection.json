{
  "info": {
    "name": "Day6 – Walid Admin Polish Tests",
    "description": "Tests for: user search by name, bulk suspend, report stats",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000/api" },
    { "key": "system_admin_token", "value": "" },
    { "key": "system_admin_email", "value": "your_admin@email.com" },
    { "key": "system_admin_password", "value": "your_password" },
    { "key": "target_user_id_1", "value": "" },
    { "key": "target_user_id_2", "value": "" }
  ],
  "item": [
    {
      "name": "━━━ SETUP ━━━",
      "item": [
        {
          "name": "1 Login as system_admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{system_admin_email}}\",\n  \"password\": \"{{system_admin_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has accessToken', () => pm.expect(json.data.accessToken).to.be.a('string'));",
                  "pm.collectionVariables.set('system_admin_token', json.data.accessToken);",
                  "console.log('✅ Token saved');"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "━━━ 1. REPORT STATS ━━━",
      "item": [
        {
          "name": "2 GET /admin/reports/stats",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{system_admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/reports/stats",
              "host": ["{{base_url}}"],
              "path": ["admin", "reports", "stats"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('success true', () => pm.expect(json.success).to.be.true);",
                  "pm.test('Has total field', () => pm.expect(json.data.total).to.be.a('number'));",
                  "pm.test('Has byReason', () => pm.expect(json.data.byReason).to.be.an('object'));",
                  "pm.test('Has byStatus', () => pm.expect(json.data.byStatus).to.be.an('object'));",
                  "pm.test('byStatus has pending key', () => pm.expect(json.data.byStatus).to.have.property('pending'));",
                  "console.log('📊 Report stats:', JSON.stringify(json.data, null, 2));"
                ]
              }
            }
          ]
        },
        {
          "name": "3 GET /admin/reports/stats — unauthorized (no token)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admin/reports/stats",
              "host": ["{{base_url}}"],
              "path": ["admin", "reports", "stats"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Rejects unauthenticated (401)', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "━━━ 2. USER SEARCH BY NAME ━━━",
      "item": [
        {
          "name": "4 GET /admin/users — list all (save 2 IDs)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{system_admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users?role=employee&limit=5",
              "host": ["{{base_url}}"],
              "path": ["admin", "users"],
              "query": [
                { "key": "role", "value": "employee" },
                { "key": "limit", "value": "5" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has data array', () => pm.expect(json.data).to.be.an('array'));",
                  "pm.test('Has pagination', () => pm.expect(json.pagination).to.have.property('total'));",
                  "pm.test('Has pages field', () => pm.expect(json.pagination).to.have.property('pages'));",
                  "if (json.data.length >= 1) {",
                  "  pm.collectionVariables.set('target_user_id_1', json.data[0].id);",
                  "  console.log('💾 Saved user ID 1:', json.data[0].id);",
                  "}",
                  "if (json.data.length >= 2) {",
                  "  pm.collectionVariables.set('target_user_id_2', json.data[1].id);",
                  "  console.log('💾 Saved user ID 2:', json.data[1].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "5 GET /admin/users?search=email (search by email)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{system_admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users?search=gmail",
              "host": ["{{base_url}}"],
              "path": ["admin", "users"],
              "query": [
                { "key": "search", "value": "gmail" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Returns array', () => pm.expect(json.data).to.be.an('array'));",
                  "pm.test('Has pagination.pages', () => pm.expect(json.pagination.pages).to.be.a('number'));",
                  "console.log('🔍 Email search results:', json.data.length, 'users, total:', json.pagination.total);"
                ]
              }
            }
          ]
        },
        {
          "name": "6 GET /admin/users?search=name (search by full name)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{system_admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users?search=Baraa",
              "host": ["{{base_url}}"],
              "path": ["admin", "users"],
              "query": [
                { "key": "search", "value": "Baraa" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Returns array', () => pm.expect(json.data).to.be.an('array'));",
                  "console.log('🔍 Name search results:', json.data.length, 'users');"
                ]
              }
            }
          ]
        },
        {
          "name": "7 GET /admin/users?search=empty (no results)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{system_admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/admin/users?search=zzznomatch999",
              "host": ["{{base_url}}"],
              "path": ["admin", "users"],
              "query": [
                { "key": "search", "value": "zzznomatch999" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Returns empty array', () => pm.expect(json.data).to.be.an('array').that.has.lengthOf(0));",
                  "pm.test('Total is 0', () => pm.expect(json.pagination.total).to.equal(0));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "━━━ 3. BULK SUSPEND ━━━",
      "item": [
        {
          "name": "8 PATCH /admin/users/bulk-suspend — missing body",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{system_admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/admin/users/bulk-suspend",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "bulk-suspend"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Rejects missing userIds (400)', () => pm.response.to.have.status(400));",
                  "const json = pm.response.json();",
                  "pm.test('Error code MISSING_FIELD', () => pm.expect(json.error.code).to.equal('MISSING_FIELD'));"
                ]
              }
            }
          ]
        },
        {
          "name": "9 PATCH /admin/users/bulk-suspend — missing reason",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{system_admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userIds\": [\"{{target_user_id_1}}\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/users/bulk-suspend",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "bulk-suspend"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Rejects missing reason (400)', () => pm.response.to.have.status(400));",
                  "const json = pm.response.json();",
                  "pm.test('Error code MISSING_FIELD', () => pm.expect(json.error.code).to.equal('MISSING_FIELD'));"
                ]
              }
            }
          ]
        },
        {
          "name": "10 PATCH /admin/users/bulk-suspend — success",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{system_admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userIds\": [\"{{target_user_id_1}}\", \"{{target_user_id_2}}\"],\n  \"reason\": \"Violation of terms of service\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/users/bulk-suspend",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "bulk-suspend"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('success true', () => pm.expect(json.success).to.be.true);",
                  "pm.test('Has suspended count', () => pm.expect(json.data.suspended).to.be.a('number'));",
                  "pm.test('Has skipped count', () => pm.expect(json.data.skipped).to.be.a('number'));",
                  "pm.test('Has suspendedIds array', () => pm.expect(json.data.suspendedIds).to.be.an('array'));",
                  "console.log('🔨 Bulk suspend result:', JSON.stringify(json.data, null, 2));"
                ]
              }
            }
          ]
        },
        {
          "name": "11 PATCH /admin/users/bulk-suspend — already suspended (skipped)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{system_admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userIds\": [\"{{target_user_id_1}}\", \"{{target_user_id_2}}\"],\n  \"reason\": \"Second attempt — should skip all\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/users/bulk-suspend",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "bulk-suspend"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 400 NO_ELIGIBLE_USERS', () => pm.response.to.have.status(400));",
                  "const json = pm.response.json();",
                  "pm.test('Error code NO_ELIGIBLE_USERS', () => pm.expect(json.error.code).to.equal('NO_ELIGIBLE_USERS'));",
                  "pm.test('skipped list populated', () => pm.expect(json.skipped).to.be.an('array').with.length.greaterThan(0));"
                ]
              }
            }
          ]
        },
        {
          "name": "12 PATCH /admin/users/bulk-suspend — limit exceeded (101 IDs)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{system_admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userIds\": [\"a\",\"b\",\"c\",\"d\",\"e\",\"f\",\"g\",\"h\",\"i\",\"j\",\"a\",\"b\",\"c\",\"d\",\"e\",\"f\",\"g\",\"h\",\"i\",\"j\",\"a\",\"b\",\"c\",\"d\",\"e\",\"f\",\"g\",\"h\",\"i\",\"j\",\"a\",\"b\",\"c\",\"d\",\"e\",\"f\",\"g\",\"h\",\"i\",\"j\",\"a\",\"b\",\"c\",\"d\",\"e\",\"f\",\"g\",\"h\",\"i\",\"j\",\"a\",\"b\",\"c\",\"d\",\"e\",\"f\",\"g\",\"h\",\"i\",\"j\",\"a\",\"b\",\"c\",\"d\",\"e\",\"f\",\"g\",\"h\",\"i\",\"j\",\"a\",\"b\",\"c\",\"d\",\"e\",\"f\",\"g\",\"h\",\"i\",\"j\",\"a\",\"b\",\"c\",\"d\",\"e\",\"f\",\"g\",\"h\",\"i\",\"j\",\"a\",\"b\",\"c\",\"d\",\"e\",\"f\",\"g\",\"h\",\"i\",\"j\",\"x\"],\n  \"reason\": \"Too many\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/users/bulk-suspend",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "bulk-suspend"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Rejects over-limit (400)', () => pm.response.to.have.status(400));",
                  "const json = pm.response.json();",
                  "pm.test('Error code LIMIT_EXCEEDED', () => pm.expect(json.error.code).to.equal('LIMIT_EXCEEDED'));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
