            }
          ]
        },
        {
          "name": "10 GET /companies — sorted alphabetical",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/companies?sortBy=name&sortOrder=asc&limit=5",
              "host": ["{{base_url}}"],
              "path": ["companies"],
              "query": [
                { "key": "sortBy",    "value": "name" },
                { "key": "sortOrder", "value": "asc" },
                { "key": "limit",     "value": "5" }
